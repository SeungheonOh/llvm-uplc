/* Generated by CMake from build_paths.h.in — do not edit by hand. */
#ifndef UPLC_BUILD_PATHS_H
#define UPLC_BUILD_PATHS_H

/*
 * Absolute paths discovered at configure time and consumed by
 * `uplcc emit-exe` to invoke the system linker without depending on
 * environment variables, $PATH, or the source-tree layout.
 *
 * Every path is fixed at the time the uplcc binary was built. Moving the
 * build tree after install will break emit-exe; that is expected for a
 * developer tool and matches how a typical compiler driver works.
 */

/* C++ compiler (used as the linker driver — pulls in libc++/libstdc++,
 * libm, libSystem on macOS, etc.). */
#define UPLC_CXX_COMPILER       "@CMAKE_CXX_COMPILER@"

/* In-tree archives — produced by this build. */
#define UPLC_RUNTIME_LIB        "@UPLC_RUNTIME_LIB_PATH@"
#define UPLC_RUNNER_LIB         "@UPLC_RUNNER_LIB_PATH@"
#define UPLC_FRONTEND_LIB       "@UPLC_FRONTEND_LIB_PATH@"
#define UPLC_BLST_LIB           "@UPLC_BLST_LIB_PATH@"

/* System static crypto / arithmetic dependencies (located via find_library). */
#define UPLC_GMP_STATIC         "@UPLC_GMP_STATIC@"
#define UPLC_SODIUM_STATIC      "@UPLC_SODIUM_STATIC@"
#define UPLC_CRYPTO_STATIC      "@UPLC_CRYPTO_STATIC@"
#define UPLC_SECP256K1_STATIC   "@UPLC_SECP256K1_STATIC@"

#endif  /* UPLC_BUILD_PATHS_H */
